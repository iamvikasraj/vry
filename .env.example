# Formspree form id for workshop RSVPs (e.g. "xyzabc" from https://formspree.io/f/xyzabc)
# Create a form at https://formspree.io and add the form id here to collect RSVPs on your site.
NEXT_PUBLIC_FORMSPREE_RSVP=

# Portfolio chat — use Grok (xAI) OR OpenAI. If XAI_API_KEY is set, Grok is used.
# Grok: https://console.x.ai/team/default/api-keys
XAI_API_KEY=
# Optional Grok model (see https://docs.x.ai/docs/models ). Default: grok-4-1-fast-non-reasoning
# XAI_MODEL=grok-4-1-fast-non-reasoning

# OpenAI (only used if XAI_API_KEY is not set)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
