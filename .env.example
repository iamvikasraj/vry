# Formspree form id for workshop RSVPs (e.g. "xyzabc" from https://formspree.io/f/xyzabc)
# Create a form at https://formspree.io and add the form id here to collect RSVPs on your site.
NEXT_PUBLIC_FORMSPREE_RSVP=

# Portfolio chat (Ti) — Grok (xAI) OR OpenAI. If XAI_API_KEY is set, Grok is used.
#
# Local: copy to .env.local and run `npm run dev` (uses Next /api/chat).
#
# Netlify (production): Site configuration → Environment variables
#   - Add XAI_API_KEY and/or OPENAI_API_KEY (exact names; values are secret).
#   - Scope: include “Functions” (serverless runtime). If a variable is only scoped to
#     “Builds”, the chat function will NOT see it and Ti will show “not configured”.
#   - Deploy contexts: add the same vars for Deploy previews if you test PR/preview URLs.
#   - After saving, trigger a new deploy (Deploys → Trigger deploy → Deploy site).
# Static export does not ship Next API routes; /api/chat is rewritten to a Netlify Function.
# Grok: https://console.x.ai/team/default/api-keys
XAI_API_KEY=
# Optional Grok model (see https://docs.x.ai/docs/models ). Default: grok-4-1-fast-non-reasoning
# XAI_MODEL=grok-4-1-fast-non-reasoning

# OpenAI (only used if XAI_API_KEY is not set)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Home terminal: show the “Companies I’ve worked with” block (omit or leave unset to keep it hidden)
# NEXT_PUBLIC_HOME_TERMINAL_SHOW_COMPANIES=true

# Home terminal: show the ~/work project index + catalog block (omit or leave unset to keep it hidden)
# NEXT_PUBLIC_HOME_TERMINAL_SHOW_PROJECT_INDEX=true

# GitHub contribution graph (server-only; never use NEXT_PUBLIC_ for the token)
# GITHUB_TOKEN=
# GITHUB_CONTRIBUTIONS_LOGIN=iamvikasraj
# Optional: repo name under that login to show with star count next to contributions (default: swiftuibuttons)
# GITHUB_SHOWCASE_REPO=swiftuibuttons
